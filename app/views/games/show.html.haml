%table
  %tr
    %td(style="border:1px solid")
      %input(type='button' name="11" id="11")
    %td(style="border:1px solid")
      %input(type='button' name="12" id="12")
    %td(style="border:1px solid")
      %input(type='button' name="13" id="13")
  %tr
    %td(style="border:1px solid")
      %input(type='button' name="21" id="21")
    %td(style="border:1px solid")
      %input(type='button' name="22" id="22")
    %td(style="border:1px solid")
      %input(type='button' name="23" id="23")
  %tr
    %td(style="border:1px solid")
      %input(type='button' name="31" id="31")
    %td(style="border:1px solid")
      %input(type='button' name="32" id="32")
    %td(style="border:1px solid")
      %input(type='button' name="33" id="33")

:javascript
  $(function(){
    $.get('/games/'+'#{@token}'+'.json', function(data){
      var board = data.board;
      var cells = ['11', '12', '13', '21', '22', '23', '31', '32', '33'] 

      for(var i = 0; i < cells.length; i++){
        var cell = cells[i];
        if(board[cell]){
          $('input[id='+cell+']').replaceWith(board[cell]);
        }
      }
    });

    $('input[type=button]').on('click', function(){
      $.ajax({
        url: '/games/'+'#{@token}'+'.json',
        type: 'put',
        data: {game: {cell: this.name}}
      }).done(function(data){
        alert('thanks...');
      }).fail(function(data){
        alert('it is not your turn...');
      });
    })

    var pusher = new Pusher('68c5c3481ddbd8d2912d', {
      encrypted: true
    });

    var channel = pusher.subscribe('game');
    channel.bind('change', function(data) {

      var board = data.message.board

      cell = Object.keys(board)[0];
      value = board[cell];
      id = cell + value;

      $('input[name='+cell+']').replaceWith(value);
    });
  });

